-include "io.scl"

fn main() : i32 {
  i32 base
  i32 exponent
  i32 result = 1
  i32 counter = 0
  
  printf("Enter base and exponent: ")
  scanf("%d%d", &base, &exponent)
  
  if exponent == 0 goto :end
  
  while counter < exponent {
    result = result * base
    counter = counter + 1
  }
  
  :end
  printf("%d\n", result)
  
  return 0
}
