-include "io.scl"

fn main() : i32 {
  i32 n

  printf("Enter a number: ")
  scanf("%d", &n)
  
  if n == 0 printf("0\n") 
  if n == 1 printf("1\n") 
  
  i32 a = 0
  i32 b = 1
  i32 count = 2
  i32 fib = 0
  
  while count < n {
    fib = a + b
    a = b
    b = fib
    count = count + 1
  }
  
  printf("%dth fibobacci number: %d\n", n, fib)
  return 0
}
